# ── Copy this file to .env and fill in your values ──────────────────────────
# NEVER put real credentials here – this file is safe to share/commit

# Upstox API  (https://developer.upstox.com/)
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=                     # auto-updated by token_manager.py each morning
UPSTOX_REDIRECT_URI=http://127.0.0.1/

# Telegram Bot  (create via @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Risk / Capital
MAX_CAPITAL_PER_TRADE=100000
MAX_OPEN_POSITIONS=3
STOP_LOSS_PCT=5.0
TARGET_PROFIT_PCT=10.0
MAX_DAILY_LOSS=1000
TRAILING_STOP_PCT=1.0

# Set to "false" to enable LIVE trading  (keep "true" until fully tested!)
PAPER_TRADE=true
